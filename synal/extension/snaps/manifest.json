{
  "manifest_version": 3,
  "name": "Snaps by Synal",
  "version": "1.0.1",
  "description": "Capture signals, create tasks, feed orchestration.",
  "author": "Synal",
  "icons": {"16":"icons/icon16.png","48":"icons/icon48.png","128":"icons/icon128.png"},
  "action": {"default_popup":"popup.html","default_icon":{"16":"icons/icon16.png","48":"icons/icon48.png"},"default_title":"Snaps by Synal"},
  "background": {"service_worker":"js/background.js","type":"module"},
  "content_scripts": [{"matches":["<all_urls>"],"js":["js/content.js"],"run_at":"document_idle"}],
  "side_panel": {"default_path":"sidepanel.html"},
  "permissions": ["activeTab","scripting","storage","tabs","contextMenus","sidePanel"],
  "host_permissions": [],
  "commands": {"_execute_action": {"suggested_key":{"default":"Alt+S"},"description":"Open Snaps"}},
  "content_security_policy": {"extension_pages":"script-src 'self'; object-src 'self'"}
}
